ui = true
disable_mlock = true

listener "tcp" {
  address        = "0.0.0.0:{{ vault_port }}"
  tls_cert_file  = "{{ vault_tls_path }}/vault.crt"
  tls_key_file   = "{{ vault_tls_path }}/vault.key"
}

storage "file" {
  path = "{{ vault_storage_path }}"
}

api_addr = "https://{{ vault_fqdn }}:{{ vault_port }}"
